// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "cursor": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "relative_line_numbers": "enabled",
  "context_servers": {
    "Figma desktop": {
      "enabled": true,
      "url": "http://127.0.0.1:3845/mcp",
    },
  },
  "git": {
    "hunk_style": "staged_hollow",
    "git_gutter": "tracked_files",
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "notification_panel": {
    "button": false,
  },
  "indent_guides": {
    "line_width": 3,
    "active_line_width": 4,
    "background_coloring": "disabled",
    "coloring": "indent_aware",
    "enabled": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "show_wrap_guides": true,
  "cursor_blink": false,
  "git_panel": {
    "status_style": "label_color",
    "sort_by_path": true,
    "scrollbar": {
      "show": "auto",
    },
    "collapse_untracked_diff": false,
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Bearded Icon Theme",
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "dock": "left",
    "enabled": true,
    "button": true,
    "model_parameters": [],
  },
  "tab_bar": {
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
    "show": true,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 6000,
    },
  },
  "linked_edits": true,
  "show_whitespaces": "all",
  "wrap_guides": [],
  "ui_font_size": 16,
  "buffer_font_size": 17.0,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Halcyon",
  },
}
